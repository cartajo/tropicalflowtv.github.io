const fsBtn = document.getElementById('promoFs');
const promoWrapper = document.getElementById('promoShell');

fsBtn.onclick = () => {

  if (!document.fullscreenElement) {

    // Activar fullscreen limpio
    promoWrapper.requestFullscreen?.().then(() => {
      promoWrapper.style.width = "100vw";
      promoWrapper.style.height = "100vh";
    });

  } else {

    document.exitFullscreen?.();

  }
};

// Restaurar automáticamente cuando se sale del fullscreen
document.addEventListener("fullscreenchange", () => {
  if (!document.fullscreenElement) {
    promoWrapper.style.width = "";
    promoWrapper.style.height = "";
  }
});
